GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
MEMORY_DB_PATH=memory.db
# Diagnostics off by default; set AGENT_DEBUG=1 to print [TOOL]/[VERIFY] to stderr
AGENT_DEBUG=0
# Set AGENT_LOG_ENABLED=1 to write diagnostics to AGENT_LOG_PATH (default agent.log)
AGENT_LOG_ENABLED=0
AGENT_LOG_PATH=agent.log
